# CocoaPods returns command output as ASCII-8BIT. React Native's podspecs join
# that output with UTF-8 paths, which fails when the repository path is not
# ASCII. Normalize command output once here instead of patching node_modules.
class << Pod::Executable
  unless method_defined?(:execute_command_without_utf8_path_support)
    alias_method :execute_command_without_utf8_path_support, :execute_command

    def execute_command(*args)
      execute_command_without_utf8_path_support(*args).force_encoding(Encoding::UTF_8)
    end
  end
end

# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'DigitalEmployee' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )
  end
end
